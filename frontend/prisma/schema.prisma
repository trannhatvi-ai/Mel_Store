generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  AWAITING_DEPOSIT
  PAID
  SERVICE_ONGOING
  COMPLETED
  CANCELLED

  @@map("order_status")
}

enum UserRole {
  GUEST
  STUDIO
  ADMIN

  @@map("user_role")
}

enum UserPermission {
  VIEW
  EDIT

  @@map("user_permission")
}

model Category {
  id       String    @id
  slug     String    @unique
  name     Json
  products Product[]

  @@map("categories")
}

model Product {
  id           String      @id
  slug         String      @unique
  name         Json
  categoryId   String      @map("category")
  category     Category    @relation(fields: [categoryId], references: [id])
  price        Int
  pricePerDay  Boolean     @default(false) @map("price_per_day")
  image        String
  gallery      Json
  description  Json
  details      Json
  available    Boolean     @default(true)
  trending     Boolean     @default(false)
  discount     Int         @default(0)
  embedding    Unsupported("vector")?
  searchVector Unsupported("tsvector")? @map("search_vector")
  orderItems   OrderItem[]
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([categoryId])
  @@map("products")
}

model User {
  id             String         @id
  email          String         @unique
  username       String         @unique
  hashedPassword String?        @map("hashed_password")
  fullName       String?        @map("full_name")
  role           UserRole       @default(GUEST)
  permission     UserPermission @default(VIEW)
  googleId       String?        @map("google_id")
  orders         Order[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("users")
}

model Order {
  id           String      @id
  orderNumber  String      @unique @map("order_number")
  userId       String?     @map("user_id")
  user         User?       @relation(fields: [userId], references: [id])
  customer     String
  email        String
  phone        String
  items        OrderItem[]
  total        Int
  deposit      Int
  status       OrderStatus @default(AWAITING_DEPOSIT)
  eventDate    DateTime    @map("event_date") @db.Date
  notes        String?
  paymentProof String?     @map("payment_proof")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        String  @id
  orderId   String  @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  qty       Int
  price     Int
  days      Int?

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Voucher {
  id              String    @id
  code            String    @unique
  discountPercent Int       @map("discount_percent")
  active          Boolean   @default(true)
  expiresAt       DateTime? @map("expires_at")

  @@map("vouchers")
}

model StorePolicy {
  id           String                 @id
  policyType   String                 @map("policy_type")
  locale       String                 @default("vi")
  title        String?
  content      String
  embedding    Unsupported("vector")?
  searchVector Unsupported("tsvector")? @map("search_vector")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  @@index([policyType])
  @@index([locale])
  @@map("store_policies")
}

model AISetting {
  id                 Int      @id @default(1)
  chatProvider       String   @default("gemini") @map("chat_provider")
  chatModel          String   @default("gemini-2.0-flash") @map("chat_model")
  embeddingProvider  String   @default("gemini") @map("embedding_provider")
  embeddingModel     String   @default("gemini-embedding-001") @map("embedding_model")
  googleClientId     String?  @map("google_client_id")
  googleClientSecret String?  @map("google_client_secret")
  databaseUrl        String?  @map("database_url")
  systemPrompt       String?  @map("system_prompt")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("ai_settings")
}

model StudioProfile {
  id              Int      @id @default(1)
  name            String   @default("Feli Studio")
  address         String   @default("23 Dong Khoi, District 1, Saigon")
  email           String   @default("hello@felistudio.vn")
  bankName        String   @default("Vietcombank") @map("bank_name")
  bankAccount     String   @default("0123 456 789") @map("bank_account")
  bankBeneficiary String   @default("FELI STUDIO") @map("bank_beneficiary")
  facebookLink    String?  @map("facebook_link")
  instagramLink   String?  @map("instagram_link")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("studio_profile")
}
